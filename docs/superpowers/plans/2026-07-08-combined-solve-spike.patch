+function _combined_state_dependent_exprs(am::AllostericMechanism)
+    function state_system(state)
+        cm = _state_mechanism(am, state)
+        sp = _state_step_params(am, state)
+        _assemble_constraints(cm, _state_wegscheider_rename_map(am, state);
+                              step_params = sp, all_params = _state_all_params(cm, sp))
+    end
+    A_A, rhs_A, cols_A, pri_A = state_system(:A)
+    A_I, rhs_I, cols_I, pri_I = state_system(:I)
+
+    # Combined columns: the A-state columns, then any I-only column (a shared
+    # `:EqualAI` group carries the same bare Symbol in both states and coincides).
+    #
+    # Priority remap, scoped to the combined solve (the shared kernel is untouched):
+    #  (1) shift every column +1 above the free-enzyme-binding sentinel (-1) that
+    #      `_solve_dependent_set` treats as never-pivot, so a constraint row whose
+    #      surviving columns are all binding-K's — a cross-state affinity split OR an
+    #      A-state binding-K Wegscheider tie — pivots instead of dropping silently;
+    #  (2) offset I-columns above EVERY A-column so a pinned split collapses onto the
+    #      free A-side affinity (`K_I = K_A`). Within-state order is preserved, so a
+    #      steady-state I-binding's reverse `koff_I` outranks its forward `kon_I`: the
+    #      affinity collapses, the speed stays free. A dead-I split (no I-row) has no
+    #      row to pivot it and stays free.
+    ioffset = maximum(pri_A; init = 0) + 2
+    columns = copy(cols_A)
+    col_index = Dict(c => i for (i, c) in enumerate(columns))
+    priority = [p + 1 for p in pri_A]
+    for (j, c) in enumerate(cols_I)
+        haskey(col_index, c) && continue
+        push!(columns, c)
+        col_index[c] = length(columns)
+        push!(priority, pri_I[j] + 1 + ioffset)
+    end
+
+    # Stack the two per-state constraint blocks over the combined column space.
+    A = zeros(Rational{BigInt}, size(A_A, 1) + size(A_I, 1), length(columns))
+    for i in axes(A_A, 1), (j, c) in enumerate(cols_A)
+        A_A[i, j] == 0 || (A[i, col_index[c]] = A_A[i, j])
+    end
+    off = size(A_A, 1)
+    for i in axes(A_I, 1), (j, c) in enumerate(cols_I)
+        A_I[i, j] == 0 || (A[off + i, col_index[c]] = A_I[i, j])
+    end
+    rhs = vcat(rhs_A, rhs_I)
+    return _solve_dependent_set(A, rhs, columns, priority)
+end
